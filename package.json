{
  "name": "cardio-club-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:ecg": "tsx scripts/seed-ecg-base.ts",
    "db:seed:video": "tsx scripts/seed-videolectures.ts",
    "admin:make": "tsx scripts/make-admin.ts",
    "db:seed:demo": "tsx scripts/seed-demo-content.ts",
    "demo:check": "tsx scripts/demo-check.ts",
    "prod:build": "npm run lint && npm run demo:check && npm run build",
    "prod:start": "next start",
    "demo:serve": "next start -p 3001",
    "demo:win": "powershell -ExecutionPolicy Bypass -File scripts/start-demo-local.ps1",
    "demo:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-demo-public-link.ps1",
    "demo:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-demo.ps1",
    "subscriptions:expire": "tsx scripts/expire-subscriptions.ts",
    "premium:check": "tsx scripts/premium-access-check.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "next": "16.0.10",
    "prisma": "^7.8.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.11.1": true,
    "better-sqlite3@12.11.1": true
  }
}
