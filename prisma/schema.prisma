generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  emailVerifiedAt DateTime?
  name            String?
  role            String    @default("USER")

  profile                 Profile?
  subscriptions           Subscription[]
  payments                Payment[]
  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  oauthAccounts           OAuthAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  avatarUrl String?
  phone     String?
  city      String?
  bio       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id   String @id @default(cuid())
  code String @unique

  title       String
  description String?

  durationDays      Int?
  priceMinor        Int
  monthlyPriceMinor Int?
  currency          String @default("RUB")

  isPremium Boolean @default(true)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  subscriptions Subscription[]
  payments      Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([isPremium, isActive])
}

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Снимок кода тарифа сохраняется для истории и безопасной миграции.
  plan String @default("FREE")

  planId     String?
  planRecord Plan?   @relation(fields: [planId], references: [id], onDelete: SetNull)

  status   String    @default("ACTIVE")
  startsAt DateTime  @default(now())
  endsAt   DateTime?

  cancelAtPeriodEnd Boolean   @default(false)
  canceledAt        DateTime?

  provider               String  @default("INTERNAL")
  providerSubscriptionId String?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([planId, status])
  @@index([endsAt])
  @@index([provider, providerSubscriptionId])
}

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  provider          String
  providerPaymentId String?
  idempotencyKey    String  @unique

  status      String @default("PENDING")
  amountMinor Int
  currency    String

  checkoutUrl String?
  failureCode String?

  paidAt     DateTime?
  canceledAt DateTime?
  refundedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status, createdAt])
  @@index([planId])
  @@index([subscriptionId])
  @@index([provider, providerPaymentId])
}

model ContentArea {
  id           String  @id @default(cuid())
  title        String
  slug         String  @unique
  description  String?
  materialType String
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)

  categories Category[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Category {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  subsectionKind String @default("NONE")

  contentAreaId String?
  contentArea   ContentArea? @relation(fields: [contentAreaId], references: [id], onDelete: SetNull)

  materials            Material[]
  ecgSections          EcgSection[]
  videoLectureSections VideoLectureSection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contentAreaId, isActive, sortOrder])
}

model EcgSection {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  materials Material[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, isActive, sortOrder])
}

model VideoLectureSection {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  materials Material[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, isActive, sortOrder])
}

model Material {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String?
  content     String?
  type        String
  imageUrl    String?
  videoUrl    String?
  isPremium   Boolean @default(false)
  isPublished Boolean @default(false)

  categoryId            String?
  ecgSectionId          String?
  videoLectureSectionId String?
  category              Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ecgSection            EcgSection?          @relation(fields: [ecgSectionId], references: [id], onDelete: SetNull)
  videoLectureSection   VideoLectureSection? @relation(fields: [videoLectureSectionId], references: [id], onDelete: SetNull)
  sortOrder             Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isPublished])
  @@index([categoryId, isPublished, sortOrder])
  @@index([ecgSectionId, isPublished, sortOrder])
  @@index([videoLectureSectionId, isPublished, sortOrder])
  @@index([isPublished, updatedAt])
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model OAuthAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          String
  providerAccountId String
  email             String?
  name              String?
  avatarUrl         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
}
